[
  {
    "label": "revdiff: run",
    "command": "go run ./app --dbg",
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  },
  {
    "label": "revdiff: run staged",
    "command": "go run ./app --staged --dbg",
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false
  },
  {
    "label": "build",
    "command": "make build",
    "cwd": "$ZED_WORKTREE_ROOT"
  },
  {
    "label": "test",
    "command": "make test",
    "cwd": "$ZED_WORKTREE_ROOT"
  }
]
